FROM harbor.kigawa.net/library/dev-base:latest

RUN curl -fsSL https://claude.ai/install.sh | bash && \
    ln -sf /root/.claude/local/claude /usr/local/bin/claude

ENV JAVA_HOME=/opt/java/openjdk
WORKDIR /work
COPY ktcl-claudecode/build/libs/ktcl-claudecode-all.jar /app/app.jar
ENTRYPOINT ["java"]
CMD ["-jar","/app/app.jar"]
