FROM harbor.kigawa.net/library/dev-base:latest

RUN useradd -m -s /bin/bash appuser

USER appuser
RUN curl -fsSL https://claude.ai/install.sh | bash

USER root
ENV JAVA_HOME=/opt/java/openjdk
ENV PATH="/home/appuser/.local/bin:${PATH}"
WORKDIR /work
COPY --chown=appuser:appuser ktcl-claudecode/build/libs/ktcl-claudecode-all.jar /app/app.jar

USER appuser
ENTRYPOINT ["java"]
CMD ["-jar","/app/app.jar"]
