{
    "extends": [
        "schedule:automergeDaily",
        ":dependencyDashboard",
        "config:recommended"
    ],
    "rebaseWhen": "behind-base-branch",
    "prConcurrentLimit": 0,
    "prHourlyLimit": 0,
    "packageRules": [
        {
            "matchUpdateTypes": ["minor", "patch", "major"],
            "automerge": true,
            "requiredStatusChecks": ["CI"],
            "automergeType": "pr"
        }
    ]
}
