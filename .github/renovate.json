{
    "extends": [
        "schedule:automergeDaily",
        ":dependencyDashboard",
        "config:recommended"
    ],
    "rebaseWhen": "behind-base-branch",
    "prConcurrentLimit": 0,
    "prHourlyLimit": 0,
    "packageRules": [
        {
            "automerge": true,
            "requiredStatusChecks": [
                "CI"
            ],
            "automergeType": "pr"
        },
        {
            "matchUpdateTypes": [
                "patch",
                "major"
            ],
            "automerge": true,
            "requiredStatusChecks": [
                "CI"
            ],
            "automergeType": "pr"
        }
    ]
}
