----+import {useWebsocketState, WebsocketLoadedState, WebsocketState} from "./Websocket";
----+import {useEffect} from "react";
----+import {useKerutaTaskState} from "./KerutaTask";
----+
----+export default function WsSender(
----+    {}: {},
----+) {
----+    const wsState = useWebsocketState()
----+    const kerutaState = useKerutaTaskState()
----+
----+    useEffect(() => {
----+        if (wsState.state != "loaded") return
----+        if (kerutaState.state != "connected") return
----+        if (kerutaState.auth.state == "unauthenticated") {
----+            sendAuth(wsState)
----+        }
----+    }, [wsState.state]);
----+    return (
----+        <div>
----+        </div>
----+    )
----+}
----+
----+
----+function sendAuth(wsState: WebsocketLoadedState) {
----+    wsState.websocket.send(JSON.stringify({type: "auth", token: "test"}))
----+}
