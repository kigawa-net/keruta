--<+>services:\n  mysql:\n    image: mysql:8.0\n    environment:\n      - MYSQL_ROOT_PASSWORD=root\n      - MYSQL_DATABASE=keruta_test\n      - MYSQL_USER=keruta\n      - MYSQL_PASSWORD=keruta\n    healthcheck:\n      test: [\"CMD\", \"mysqladmin\", \"ping\", \"-h\", \"localhost\", \"-u\", \"keruta\", \"-pkeruta\"]\n      interval: 5s\n      timeout: 3s\n      retries: 10\n    tmpfs:\n      - /var/lib/mysql\n  rsync:\n    build:\n      context: .\n      dockerfile: Dockerfile_rsync\n      cache_from:\n        - type=gha\n      cache_to:\n        - type=gha,mode=max\n    command:\n      - bash\n      - -c\n      - |\n        set -ue\n        if [ ! -d /src/cache/app ]; then mkdir -p /src/cache/app; fi\n        if [ ! -d /src/cache/.gradle ]; then mkdir -p /src/cache/.gradle; fi\n        if [ -d /src/cache/app/kotlin-js-store ]; then rm -r /src/cache/app/kotlin-js-store; fi\n        rsync -avz --delete /src/ /src/cache/app \\\n          --exclude=/.git \\\n          --exclude=/.idea \\\n          --exclude=/.claude \\\n          --exclude=/.github \\\n          --exclude=/.junie \\\n          --exclude=/.kotlin \\\n          --exclude=/.serena \\\n          --exclude=/.coder-templates \\\n          --exclude=/.gradle \\\n          --exclude=/cache \\\n          --exclude=/keruta-coder-template \\\n          --exclude=/kigawa-net-k8s \\\n          --exclude=/kotlin-js-store \\\n          --exclude=/ktcl-front/node_modules \\\n          --exclude=/ktcl-front/dist \\\n          --exclude=/*/build \\\n          --exclude=/build \\\n          --exclude=/*/*/build\n    volumes:\n      - type: bind\n        source: .\n        target: /src\n  ktcl-front-test:\n    image: node\n    command:\n      - bash\n      - -c\n      - |\n        set -ue\n        npm install\n        npm run test\n    working_dir: /app/ktcl-front\n    depends_on:\n      rsync:\n        condition: service_completed_successfully\n    environment:\n      - VITE_WEBSOCKET_URL=ws://localhost:8080/ws/ktcp\n   