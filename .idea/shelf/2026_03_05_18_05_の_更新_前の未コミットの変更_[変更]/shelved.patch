<+>services:\n  mysql:\n    image: mysql:8.0\n    environment:\n      - MYSQL_ROOT_PASSWORD=root\n      - MYSQL_DATABASE=keruta_test\n      - MYSQL_USER=keruta\n      - MYSQL_PASSWORD=keruta\n    healthcheck:\n      test: [\"CMD\", \"mysqladmin\", \"ping\", \"-h\", \"localhost\", \"-u\", \"keruta\", \"-pkeruta\"]\n      interval: 5s\n      timeout: 3s\n      retries: 10\n    tmpfs:\n      - /var/lib/mysql\n  rsync:\n    build:\n      context: .\n      dockerfile: Dockerfile_rsync\n      cache_from:\n        - type=gha\n      cache_to:\n        - type=gha,mode=max\n    command:\n      - bash\n      - -c\n      - |\n        set -ue\n        if [ ! -d /src/cache/app ]; then mkdir -p /src/cache/app; fi\n        if [ ! -d /src/cache/.gradle ]; then mkdir -p /src/cache/.gradle; fi\n        if [ -d /src/cache/app/kotlin-js-store ]; then rm -r /src/cache/app/kotlin-js-store; fi\n        rsync -avz --delete /src/ /src/cache/app \\\n          --exclude=/.git \\\n          --exclude=/.idea \\\n          --exclude=/.claude \\\n          --exclude=/.github \\\n          --exclude=/.junie \\\n          --exclude=/.kotlin \\\n          --exclude=/.serena \\\n          --exclude=/.coder-templates \\\n          --exclude=/.gradle \\\n          --exclude=/cache \\\n          --exclude=/keruta-coder-template \\\n          --exclude=/kigawa-net-k8s \\\n          --exclude=/kotlin-js-store \\\n          --exclude=/ktcl-front/node_modules \\\n          --exclude=/ktcl-front/dist \\\n          --exclude=/*/build \\\n          --exclude=/build \\\n          --exclude=/*/*/build\n    volumes:\n      - type: bind\n        source: .\n        target: /src\n  ktcl-front-test:\n    image: node\n    command:\n      - bash\n      - -c\n      - |\n        set -ue\n        npm install\n        npm run test\n    working_dir: /app/ktcl-front\n    depends_on:\n      rsync:\n        condition: service_completed_successfully\n    environment:\n      - VITE_WEBSOCKET_URL=ws://localhost:8080/ws/ktcp\n      - VITE_KEYCLOAK_URL=https://user.kigawa.net/\n      - VITE_KEYCLOAK_REALM=develop\n      - VITE_KEYCLOAK_CLIENT_ID=keruta\n    volumes:\n      - type: bind\n        source: ./cache/app/ktcl-front\n        target: /app/ktcl-front\n      - type: bind\n        source: ./cache/npm\n        target: /root/.npm\n\n  ktcl-front-build:\n    image: node\n    command:\n      - bash\n      - -c\n      - |\n        set -ue\n        npm install\n        npm run build\n    working_dir: /app/ktcl-front\n    depends_on:\n      rsync:\n        condition: service_completed_successfully\n    environment:\n      - VITE_WEBSOCKET_URL=ws://localhost:8080/ws/ktcp\n      - VITE_KEYCLOAK_URL=https://user.kigawa.net/\n      - VITE_KEYCLOAK_REALM=develop\n      - VITE_KEYCLOAK_CLIENT_ID=keruta\n    volumes:\n      - type: bind\n        source: ./cache/app/ktcl-front\n        target: /app/ktcl-front\n      - type: bind\n        source: ./cache/npm\n        target: /root/.npm\n\n  gradle-test:\n    build:\n      context: .\n      dockerfile: Dockerfile_test\n    command: ./gradlew test allTests\n    depends_on:\n      rsync:\n        condition: service_completed_successfully\n      mysql:\n        condition: service_healthy\n    volumes:\n      - type: bind\n        source: ./cache/app\n        target: /app\n      - type: bind\n        source: ./cache/.gradle\n        target: /root/.gradle\n    working_dir: /app\n    environment:\n      - GRADLE_OPTS=-Dorg.gradle.daemon=false\n      - CHROME_BIN=/opt/google/chrome/chrome\n      - FIREFOX_BIN=/usr/bin/firefox\n      - TEST_DB_JDBC_URL=jdbc:mysql://mysql:3306/keruta_test\n      - TEST_DB_USERNAME=keruta\n      - TEST_DB_PASSWORD=keruta\n\n  test:\n    image: busybox\n    depends_on:\n      ktcl-front-test:\n        condition: service_completed_successfully\n      gradle-test:\n        condition: service_completed_successfully\n      ktcl-front-build:\n        condition: service_completed_successfully\n
