FROM eclipse-temurin:24-jdk-noble AS builder

WORKDIR /app
COPY settings.gradle.kts gradle.properties build.gradle.kts gradlew /app/
COPY buildSrc /app/buildSrc
COPY gradle /app/gradle
COPY kodel /app/kodel
RUN --mount=type=cache,target=/root/.gradle ./gradlew compileKotlinJvm -x allTests
COPY ktcp /app/ktcp
RUN --mount=type=cache,target=/root/.gradle ./gradlew ktcp:server:compileKotlinJvm -x allTests
COPY ktse /app/ktse
RUN --mount=type=cache,target=/root/.gradle ./gradlew :ktse:build -x test

FROM eclipse-temurin:24-jdk-noble

COPY --from=builder /app/ktse/build/libs/ktse-all.jar /app/app.jar
WORKDIR /work
ENTRYPOINT ["java"]
CMD ["-jar","/app/app.jar"]
