{
  "realm": "develop",
  "enabled": true,
  "sslRequired": "external",
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "realmRoles": ["offline_access", "uma_authorization"],
      "clientRoles": {
        "account": ["manage-account", "view-profile"],
        "keruta": ["uma_authorization"]
      }
    }
  ],
  "clients": [
    {
      "clientId": "keruta",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "keruta-secret",
      "redirectUris": ["http://localhost:3000/*", "http://localhost:8080/*", "http://localhost:8081/*"],
      "webOrigins": ["http://localhost:3000", "http://localhost:8080", "http://localhost:8081"],
      "protocol": "openid-connect",
      "attributes": {
        "access.token.lifespan": "300",
        "accessTokenLifespan": "300"
      }
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "offline_access"
      },
      {
        "name": "uma_authorization"
      }
    ]
  },
  "requiredCredentials": ["password"],
  "passwordPolicy": ""
}
